# Public URLs — must be reachable by clients and listed in Caddyfile.
OPENCLOUD_FQDN="https://opencloud.example.com"
COLLABORATION_FQDN="https://collaboration.example.com"
COLLABORA_FQDN="https://collabora.example.com"
# Bare hostnames matching the FQDNs above. COLLABORA_HOST is passed to Collabora
# as --o:server_name so /hosting/discovery returns the public URL even when
# fetched internally. OPENCLOUD_HOST is passed as --o:net.frame_ancestors so
# Collabora allows itself to be iframed by the OpenCloud Web UI.
OPENCLOUD_HOST="opencloud.example.com"
COLLABORA_HOST="collabora.example.com"

# Authentik global issuer URL — the value of the `iss` claim in tokens issued
# by BOTH the web and iOS providers. This works because both Authentik
# providers are configured with Issuer mode = "Same as global", so OpenCloud's
# server-side `iss` validation accepts logins from either client.
OIDC_ISSUER_URL="https://auth.example.com/"

# Per-application OIDC discovery URL for the WEB provider. The browser SPA
# fetches this. Authentik's global /.well-known/openid-configuration does not
# exist (returns 404) — only the per-application endpoints do. The per-app
# endpoint also emits Access-Control-Allow-Origin matched against that
# provider's redirect URIs, which is what makes the cross-origin fetch work.
OIDC_WEB_METADATA_URL="https://auth.example.com/application/o/opencloud/.well-known/openid-configuration"

# Initial OpenCloud admin password — only used the first time the stack comes up.
# After that, password changes happen through the web UI or `opencloud idm`.
INITIAL_ADMIN_PASSWORD="changeme"

# Collabora admin password (for /browser/dist/admin/admin.html).
COLLABORA_PASSWORD="changeme"

# Authentik OAuth2/OpenID provider Client ID for the WEB provider. Must be
# **Public** (PKCE-only) — the OpenCloud Web UI is a browser SPA and never
# sends a secret. The iOS app authenticates against a separate Authentik
# provider with its own Client ID, configured inside the app.
OIDC_CLIENT_ID="opencloud"
